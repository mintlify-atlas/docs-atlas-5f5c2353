  "keyFeatures": [
    "RBAC access control via Casbin",
    "JWT authentication with refresh tokens",
    "Code generation tool (zero-code CRUD from DB tables)",
    "Visual form builder with drag-and-drop",
    "Multi-database support (MySQL, PostgreSQL, SQLite, SQL Server)",
    "Scheduled job management with cron expressions",
    "Swagger API documentation (auto-generated)",
    "Multi-tenant support",
    "Operation and login audit logs",
    "Server monitoring dashboard",
    "File storage (local, OSS, Qiniu, Huawei OBS)",
    "Vue front-end support (Element UI, Arco Design, Ant Design)"
  ],
